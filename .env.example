# LLM + media APIs (copy to .env and fill in)
# Gemini free tier: ~20 requests/day per model (scene + TTS writer = ~2 calls per video).
# Enable billing or use a paid key if you hit 429 RESOURCE_EXHAUSTED.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60
SCRIPT_WRITER_MODEL=gemini-2.5-flash
CAPTION_STYLER_MODEL=gemini-2.5-flash
PEXELS_API_KEY=

# Slide images: pollinations (free default), gemini, or mock (local placeholder)
IMAGE_PROVIDER=pollinations
POLLINATIONS_MODEL=flux
POLLINATIONS_TIMEOUT=180
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: TTS, media cloud, storage
TTS_PROVIDER=edge
TTS_VOICE=vi-VN-HoaiMyNeural
EVERAI_VOICE_CODE=vi_male_lenghia_mb
OUTPUT_DIR=./output
# Parent folder for orchestrator runs (each run → OUTPUT_DIR/final/, overwriting the previous run).
# Unset to use output/final/ instead.
MUSIC_DIR=assets/music
JOBS_CSV=jobs.csv
BACKGROUND_MUSIC_PATH=
# Caption overlay for slideshow (none | sentence | word). Default: none.
CAPTION_MODE=none

# Optional: Telegram delivery after batch render (Bot API sendVideo, 50 MB limit)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
