# LLM + media APIs (copy to .env and fill in)
# Gemini free tier: ~20 requests/day per model (scene + TTS writer = ~2 calls per video).
# Enable billing or use a paid key if you hit 429 RESOURCE_EXHAUSTED.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60
SCRIPT_WRITER_MODEL=gemini-2.5-flash
CAPTION_STYLER_MODEL=gemini-2.5-flash

# Slide images: pollinations (free default), chatgpt, or mock (local placeholder)
IMAGE_PROVIDER=pollinations
POLLINATIONS_MODEL=flux
POLLINATIONS_TIMEOUT=180
# ChatGPT/OpenAI image generation (separate from Gemini text LLM above)
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
# 9:16 phone portrait (matches Remotion 1080x1920 canvas); gpt-image-2 requires edges divisible by 16
OPENAI_IMAGE_SIZE=1152x2048
# auto | low | medium | high
OPENAI_IMAGE_QUALITY=auto
# compact (default, essentials) | full (long template)
OPENAI_IMAGE_PROMPT_MODE=compact

# Optional: TTS, media cloud, storage
TTS_PROVIDER=edge
TTS_VOICE=vi-VN-HoaiMyNeural
OUTPUT_DIR=./output
# Parent folder for orchestrator runs (each run → OUTPUT_DIR/final/, overwriting the previous run).
# Unset to use output/final/ instead.
MUSIC_DIR=assets/music
JOBS_CSV=jobs.csv
BACKGROUND_MUSIC_PATH=
# Caption overlay for slideshow (none | sentence | word). Default: none.
CAPTION_MODE=none

# Optional: Telegram delivery after batch render (Bot API sendVideo, 50 MB limit)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Multi-platform publish after render (comma-separated: facebook, telegram)
PUBLISH_PLATFORMS=

# Facebook Page Reels (Graph API — requires Page access token)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
# Optional; default v25.0
FACEBOOK_GRAPH_VERSION=v25.0

# Google Drive upload after render (service account JSON + folder id)
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_FOLDER_ID=
